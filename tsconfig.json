{
  "compilerOptions": {
    "alwaysStrict": true,
    "declaration": true,
    "lib": ["es2020", "WebWorker"],
    "module": "nodenext",
    "noImplicitAny": false,
    "noImplicitThis": false,
    "outDir": "./out/server",
    "skipLibCheck": true,
    "sourceMap": true,
    "strictFunctionTypes": false,
    "strictNullChecks": false,
    "target": "es2020",
    "types": ["mocha", "node"],
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "out"]
}
